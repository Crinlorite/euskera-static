# Override del hash del gate de revisión (SHA-256 del token, hex 64 chars).
# Sin definir, se usa el hash hardcodeado de fallback en src/lib/gate.ts.
# Para rotar el token sin tocar código, calcula el SHA-256 nuevo y pégalo aquí
# o, mejor, defínelo en las env vars del proyecto en Cloudflare Pages.
#
# Cómo calcular un hash nuevo (PowerShell):
#   $b = [Text.Encoding]::UTF8.GetBytes("nuevo-token")
#   [BitConverter]::ToString([Security.Cryptography.SHA256]::Create().ComputeHash($b)).Replace("-","").ToLower()
PUBLIC_GATE_HASH=
