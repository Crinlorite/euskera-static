---
import { t } from '../../i18n/ui';
import type { LocaleCode } from '../../i18n/config';
import LanguageFooter from './LanguageFooter.astro';

interface Props { locale: LocaleCode; }
const { locale } = Astro.props;
const year = new Date().getFullYear();

// App Kaixo. iOS PUBLICADA en la App Store (READY_FOR_SALE) → IOS_LIVE = true
// muestra el badge oficial con enlace vivo. Android aún sin publicar → píldora
// "Próximamente" (reutiliza la clave ya traducida levels.upcoming).
const APP_STORE_URL = 'https://apps.apple.com/app/id6784369966';
const IOS_LIVE = true;
const comingSoon = t(locale, 'levels.upcoming');
---
<footer class="site-footer">
  <div class="container-wide grid">
    <div class="brand-col">
      <strong>{t(locale, 'site.name')}</strong>
      <p>{t(locale, 'site.tagline')}</p>
      <LanguageFooter currentLocale={locale} />
    </div>
    <div>
      <h4>Proyecto</h4>
      <ul>
        <li><a href="https://github.com/Crinlorite/euskera-static" rel="noopener">GitHub</a></li>
        <li><a href={`/${locale}/sobre/`}>{t(locale, 'about.title')}</a></li>
        <li><a href={`/${locale}/feedback/`}>Reportar / Feedback</a></li>
        <li><a href={`/${locale}/privacidad/`}>Privacidad</a></li>
      </ul>
    </div>
    <div>
      <h4>Licencias</h4>
      <ul>
        <li>Código: <a href="https://github.com/Crinlorite/euskera-static/blob/main/LICENSE" rel="noopener">MIT</a></li>
        <li>Contenido: <a href="https://github.com/Crinlorite/euskera-static/blob/main/LICENSE-CONTENT" rel="noopener">CC BY-SA 4.0</a></li>
      </ul>
    </div>
    <div class="app-col">
      <h4>{t(locale, 'app.title')}</h4>
      <div class="badges">
        {IOS_LIVE && (
          <a href={APP_STORE_URL} class="badge-link" rel="noopener" aria-label="Download on the App Store">
            <img src="/app-store-badge.svg" alt="Download on the App Store" width="135" height="45" loading="lazy" />
          </a>
        )}
        {!IOS_LIVE && (
          <span class="store-pill"><span class="os">iOS</span><span class="soon">{comingSoon}</span></span>
        )}
        <span class="store-pill"><span class="os">Android</span><span class="soon">{comingSoon}</span></span>
      </div>
    </div>
  </div>
  <div class="container-wide bottom">© {year} <a href="https://crintech.pro" rel="noopener" class="brand-link">Crintech Studios</a></div>
</footer>

<style>
  .site-footer {
    background: var(--c-bg-alt);
    border-block-start: 1px solid var(--c-border);
    margin-block-start: var(--s-8);
    padding-block: var(--s-6);
    color: var(--c-text-muted);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: var(--s-6);
  }
  .brand-col { display: grid; gap: var(--s-3); align-content: start; }
  .brand-col p { margin: 0; }
  .app-col { display: grid; gap: var(--s-3); align-content: start; }
  .badges { display: grid; gap: var(--s-2); justify-items: start; }
  .badge-link { display: inline-flex; }
  .badge-link img { display: block; height: 45px; width: auto; }
  .store-pill {
    display: inline-flex; align-items: center; gap: var(--s-2);
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--c-border-strong);
    border-radius: 999px;
    font-size: 0.8rem; color: var(--c-text-muted);
  }
  .store-pill .os { font-weight: 600; color: var(--c-text); }
  .store-pill .soon { opacity: 0.85; }
  .grid h4 { margin: 0 0 var(--s-2); color: var(--c-text); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .grid ul { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--s-2); }
  .grid a { color: inherit; }
  .bottom {
    margin-block-start: var(--s-5);
    padding-block-start: var(--s-3);
    border-block-start: 1px solid var(--c-border);
    font-size: 0.875rem;
  }
  .brand-link {
    color: inherit;
    text-decoration: none;
    border-block-end: 1px dashed var(--c-border-strong);
    transition: color var(--m-base) var(--ease-out), border-color var(--m-base) var(--ease-out);
  }
  .brand-link:hover { color: var(--c-red); border-block-end-color: var(--c-red); }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; gap: var(--s-5); }
  }
</style>
