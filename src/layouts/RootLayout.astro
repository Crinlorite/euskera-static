---
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/transitions.css';
import { ViewTransitions } from 'astro:transitions';
import { LANGUAGES, DEFAULT_LOCALE, type LocaleCode } from '../i18n/config';
import { t } from '../i18n/ui';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import BetaBanner from '../components/layout/BetaBanner.astro';
import LevelGate from '../components/layout/LevelGate.svelte';

interface Props {
  locale?: LocaleCode;
  title: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
}

const {
  locale = DEFAULT_LOCALE,
  title,
  description,
  ogImage = '/og-image.png',
  bodyClass = '',
} = Astro.props;

const info = LANGUAGES[locale];
const fullTitle = `${title} · ${t(locale, 'site.name')}`;
const desc = description ?? t(locale, 'site.tagline');
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang={locale} dir={info.dir}>
  <head>
    <meta charset="UTF-8" />
    {/* viewport-fit=cover habilita las safe-area insets del notch para que el
        contenido pueda extenderse bajo la barra de estado en PWA. */}
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#FFFFFF" />
    {/* PWA en iOS: 'black-translucent' deja que la app se dibuje BAJO la barra
        de estado (gana esos píxeles); es lo más cerca del fullscreen total que
        permite iPhone. Solo aplica cuando se abre desde "Añadir a inicio". */}
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Kaixo" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="preload" href="/fonts/Manrope-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Fraunces-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale.replace('-', '_')} />
    <meta name="twitter:card" content="summary_large_image" />
    <ViewTransitions />
  </head>
  <body class={bodyClass}>
    <a class="sr-only" href="#main">{t(locale, 'common.skip-content')}</a>
    <BetaBanner locale={locale} />
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <LevelGate client:load />
    <script>
      const setupFadeIns = () => {
        const obs = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              obs.unobserve(e.target);
            }
          }
        }, { rootMargin: '0px 0px -10% 0px' });
        document.querySelectorAll('.fade-in').forEach((el) => obs.observe(el));
      };
      setupFadeIns();
      document.addEventListener('astro:page-load', setupFadeIns);
    </script>
    <script>
      // Aviso beta: descarte por sesión + publica su altura como
      // --beta-banner-h para empujar header/contenido. Re-evalúa en cada
      // navegación (view transitions recrean el DOM).
      const BB_KEY = 'euskera-static.beta-banner-dismissed';
      // Re-lee el banner vigente del DOM en cada llamada (tras un swap de view
      // transitions el nodo es nuevo). Idempotente: publica --beta-banner-h o lo
      // pone a 0 si no hay banner o está descartado.
      const applyBetaBanner = () => {
        const root = document.documentElement;
        const el = document.getElementById('beta-banner');
        if (!el) { root.style.setProperty('--beta-banner-h', '0px'); return; }
        let dismissed = false;
        try { dismissed = sessionStorage.getItem(BB_KEY) === '1'; } catch { /* private */ }
        if (dismissed) { el.style.display = 'none'; root.style.setProperty('--beta-banner-h', '0px'); }
        else { el.style.display = ''; root.style.setProperty('--beta-banner-h', el.offsetHeight + 'px'); }
      };
      const setupBetaBanner = () => {
        applyBetaBanner();
        const btn = document.getElementById('beta-banner-dismiss');
        if (btn) btn.addEventListener('click', () => {
          try { sessionStorage.setItem(BB_KEY, '1'); } catch { /* private */ }
          applyBetaBanner();
        });
      };
      // resize/orientationchange se registran UNA sola vez a nivel de módulo (el
      // módulo se ejecuta una vez por sesión) y leen el banner vigente al
      // dispararse, evitando acumular un listener por cada navegación SPA.
      window.addEventListener('resize', applyBetaBanner);
      window.addEventListener('orientationchange', applyBetaBanner);
      setupBetaBanner();
      document.addEventListener('astro:page-load', setupBetaBanner);
    </script>
    <script>
      // Registra el Service Worker para PWA offline-first.
      // Solo en producción y con navegador compatible.
      if ('serviceWorker' in navigator && location.protocol === 'https:') {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/sw.js', { scope: '/' })
            .catch(() => { /* fallback silencioso si no se puede registrar */ });
        });
      }
    </script>
  </body>
</html>
