---
import RootLayout from '../../../layouts/RootLayout.astro';
import Game from '../../../components/expedition/game/components/Game.svelte';
import { ACTIVE_LOCALES, type LocaleCode } from '../../../i18n/config';

export async function getStaticPaths() {
  return ACTIVE_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: LocaleCode };
---
<RootLayout locale={locale} title="Aitonaren Hitzak — Modo Expedición" bodyClass="game-page">
  <section class="container expedicion-hero fade-in">
    <p class="eyebrow">Modo Expedición · Vista previa Steam</p>
    <h1 class="display">
      Aitonaren <span class="text-grad">Hitzak</span>.
    </h1>
    <p class="lead">
      Una aventura gráfica por Euskal Herria. Tu progreso de aprendizaje
      desbloquea capítulos. Cada lugar tiene su personaje, su misterio y
      su prueba lingüística. El final pone tu euskera al límite.
    </p>
    <p class="hint">
      Recomendado a pantalla completa. <kbd>F</kbd> activa fullscreen,
      <kbd>Esc</kbd> abre el menú, <kbd>Enter</kbd> avanza el diálogo.
    </p>
  </section>

  <section class="container game-mount fade-in">
    <Game client:only="svelte" />
  </section>

  <aside class="container game-foot fade-in">
    <p class="note">
      Esto es una <strong>vista previa funcional</strong>. El arte definitivo —
      sprites pixelart de los personajes, fondos pintados de Euskal Herria,
      música — llegará más adelante. La trama de los 8 capítulos ya se
      puede jugar de principio a fin, con dificultad creciente A1 → EGA.
    </p>
  </aside>
</RootLayout>

<style>
  .expedicion-hero {
    padding-block: var(--s-7) var(--s-4);
    display: grid;
    gap: var(--s-3);
    max-inline-size: 880px;
  }
  .expedicion-hero .eyebrow {
    margin: 0;
    font-family: var(--ff-sans);
    font-size: var(--t-eyebrow);
    font-weight: 600;
    letter-spacing: var(--tr-wide);
    text-transform: uppercase;
    color: var(--c-text-muted);
  }
  .expedicion-hero h1 {
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 0.98;
    letter-spacing: var(--tr-tight);
    margin: 0;
  }
  .expedicion-hero h1 .text-grad {
    font-style: italic;
    background: var(--grad-ikurri-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    margin: var(--s-2) 0 0;
    color: var(--c-text-muted);
    font-size: 1.05rem;
    line-height: 1.55;
    max-inline-size: 60ch;
  }
  .hint {
    margin: 0;
    color: var(--c-text-dim);
    font-size: 0.9rem;
  }
  .hint kbd {
    background: var(--c-bg-alt);
    border: 1px solid var(--c-border);
    padding: 1px 6px;
    border-radius: 3px;
    font-family: ui-monospace, monospace;
    color: var(--c-red);
    font-size: 0.78rem;
  }

  .game-mount {
    padding-block: var(--s-3) var(--s-7);
  }
  .game-foot {
    padding-block: 0 var(--s-8);
    max-inline-size: 720px;
  }
  .game-foot .note {
    color: var(--c-text-muted);
    font-size: 0.92rem;
    line-height: 1.5;
    border-block-start: 1px solid var(--c-border);
    padding-block-start: var(--s-4);
    margin: 0;
  }
  .game-foot strong { color: var(--c-text); }
</style>
